# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Optional: partner invitation emails (free — Resend) ---
# Without these, email invites are still created (they sit pending); they just
# aren't emailed out. No paid services are used anywhere in this app.
RESEND_API_KEY=
RESEND_FROM="Promise Keeper <invites@yourdomain.com>"

# Base URL used in invite links (falls back to the request host if unset).
NEXT_PUBLIC_SITE_URL=
